export OS_CLOUD=openstack
export OS_CLIENT_CONFIG_FILE="$PWD/infra/clouds.yaml"

export TF_VAR_cluster_name=msp-cluster-prod
export TF_VAR_cluster_template_name=msp-k8s-v1-30
export TF_VAR_cluster_keypair_name=msp-keypair
export TF_VAR_cluster_image_name=ubuntu-jammy-kube-v1.30.4-240828-1653
export TF_VAR_external_network_name=public
export TF_VAR_fixed_network_name=auto_allocated_network
export TF_VAR_master_count=1
export TF_VAR_node_count=1
export TF_VAR_master_flavor=m3.small
export TF_VAR_node_flavor=m3.medium
export TF_VAR_dns_nameserver=8.8.8.8
export TF_VAR_docker_volume_size=20
export TF_VAR_docker_volume_type=
export TF_VAR_boot_volume_size=0
export TF_VAR_boot_volume_type=
export TF_VAR_etcd_volume_size=0
export TF_VAR_etcd_volume_type=
export TF_VAR_network_driver=calico
export TF_VAR_volume_driver=cinder
export TF_VAR_docker_storage_driver=overlay2
export TF_VAR_kube_tag=v1.30.4
export TF_VAR_floating_ip_enabled=true
export TF_VAR_master_lb_enabled=true
export TF_VAR_create_timeout_minutes=60
export TF_VAR_monitoring_enabled=false
export TF_VAR_influx_grafana_dashboard_enabled=false
export TF_VAR_cloud_provider_enabled=true
export TF_VAR_cinder_csi_enabled=true
export TF_VAR_auto_healing_enabled=false
export TF_VAR_nova_availability_zone=nova
export TF_VAR_cinder_availability_zone=nova

export MSP_ARTIFACTS_DIR="$PWD/.artifacts/bootstrap"
export MSP_KUBECONFIG_OUT="$PWD/kubeconfig.yaml"
export MSP_SMOKE_APP_HOST=smoke.cis240470.projects.jetstream-cloud.org

# Conservative quota estimates for preflight checks. Tune these if Jetstream's
# Magnum behavior differs from your observed usage.
export MSP_ESTIMATED_FLOATING_IPS=2
export MSP_ESTIMATED_LOADBALANCERS=2
export MSP_ESTIMATED_PORTS=8
export MSP_ESTIMATED_SECURITY_GROUPS=2
export MSP_ESTIMATED_SECURITY_GROUP_RULES=24
